# SAILE Media Center - gitignore blindado
# Regra principal: nunca versionar segredos, ambientes locais, caches, builds temporários ou bancos reais de usuário.

# Segredos e credenciais
.env
.env.*
!.env.example
*.env
*.key
*.pem
*.p12
*.pfx
*.crt
*.cer
*.der
*.token
*token*
*secret*
*credential*
*credentials*
secrets/
private/

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.venv/
venv/
env/
ENV/

# Kodi/runtime local
*.db
*.sqlite
*.sqlite3
*.log
*.pid
userdata/
profile/
Kodi.log
kodi.log
Thumbnails/
Database/

# Builds e pacotes gerados
build/
dist/
*.egg-info/
*.tmp
*.bak
*.swp
*.zip.tmp

# Não ignore estes arquivos finais do repositório Kodi/GitHub Pages
!addons.xml
!addons.xml.md5
!index.html
!zips/**/*.zip

# SO/editores
.DS_Store
Thumbs.db
desktop.ini
.idea/
.vscode/
*.code-workspace

# Dumps locais de desenvolvimento
saile_dump*.md
dump_*.md
*_dump.md
backup*/
old*/

# Arquivos grandes não pertencentes ao addon
*.mp4
*.mkv
*.avi
*.mov
*.mp3
*.flac
*.torrent
*.iso
*.img
*.apk
