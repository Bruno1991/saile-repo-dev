<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="plugin.video.saile.reference"
       name="SAILE Reference Video Plugin"
       version="0.1.0"
       provider-name="SAILE">
  <requires>
    <import addon="xbmc.python" version="3.0.0"/>
  </requires>
  <extension point="xbmc.python.pluginsource" library="main.py">
    <provides>video</provides>
  </extension>
  <extension point="xbmc.addon.metadata">
    <summary lang="pt_BR">Referência arquitetural para plugins de vídeo Kodi.</summary>
    <description lang="pt_BR">Exemplo mínimo e modular para estudo. Configure uma URL MP4 autorizada nas configurações para testar playback.</description>
    <platform>all</platform>
    <license>GPL-3.0-or-later</license>
    <assets>
      <icon>icon.png</icon>
      <fanart>fanart.jpg</fanart>
    </assets>
  </extension>
</addon>
