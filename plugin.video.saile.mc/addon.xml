<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="plugin.video.saile.mc" name="Saile Media Center" version="0.1.0" provider-name="Saile">
    <requires>
        <import addon="xbmc.python" version="3.0.0" />
    </requires>
    <extension point="xbmc.python.pluginsource" library="main.py">
        <provides>video</provides>
    </extension>
    <extension point="xbmc.addon.metadata">
        <summary lang="pt_BR">Media Center local-first com IPTV, música e catálogo indexado</summary>
        <description lang="pt_BR">Saile Media Center reúne SaileTV, SaileFy e sTorrent em um addon Kodi local-first com SQLite, perfis, PIN, favoritos e continuar assistindo.</description>
        <platform>all</platform>
        <license>MIT</license>
        <assets>
            <icon>icon.png</icon>
            <fanart>fanart.png</fanart>
        </assets>
    </extension>
</addon>
